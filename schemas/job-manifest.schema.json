{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Restartable job manifest",
  "type": "object",
  "required": ["schema_version", "job_id", "command", "upstream_commit", "config_sha256", "status", "started_at"],
  "properties": {
    "schema_version": {"const": 1},
    "job_id": {"type": "string", "minLength": 1},
    "command": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "upstream_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "config_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["running", "interrupted", "complete", "failed"]},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "outputs": {"type": "object"}
  }
}
