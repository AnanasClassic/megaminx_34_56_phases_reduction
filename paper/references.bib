@misc{rokicki2025bound115,
  author       = {Rokicki, Tomas},
  title        = {Post 1675762 in ``Development of a {Megaminx} Solver''},
  year         = {2025},
  month        = nov,
  howpublished = {SpeedSolving Puzzles Community},
  note         = {Posted November 6, 2025; reports 24-move solutions, after adjoining a third face generator, for all 16 distance-26 two-generator antipodes.  This reduces the last-phase upper bound from 26 to 25 and the external total from 116 to 115; \url{https://www.speedsolving.com/threads/development-of-a-megaminx-solver.93202/post-1675762}}
}

@misc{rokicki2025bound114,
  author       = {Rokicki, Tomas},
  title        = {Post 1675972 in ``Development of a {Megaminx} Solver''},
  year         = {2025},
  month        = nov,
  howpublished = {SpeedSolving Puzzles Community},
  note         = {Posted November 8, 2025; reports that all 7,595 distance-25 two-generator positions, reduced to 1,199 representatives by symmetry and inversion, are solvable with the enlarged generator set in at most 24 moves.  This further reduces the last-phase upper bound from 25 to 24 and the external total from 115 to 114; \url{https://www.speedsolving.com/threads/development-of-a-megaminx-solver.93202/post-1675972}}
}

